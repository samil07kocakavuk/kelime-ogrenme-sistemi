<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_nav"
    android:elevation="12dp"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingTop="10dp"
    android:paddingEnd="12dp"
    android:paddingBottom="12dp">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNavHome"
        style="@style/AppButtonGhost"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/home_nav" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNavAdd"
        style="@style/AppButtonPrimary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.2"
        android:layout_marginHorizontal="8dp"
        android:minHeight="48dp"
        android:text="@string/add_nav" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNavProfile"
        style="@style/AppButtonGhost"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/profile_nav" />
</LinearLayout>
