<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:orientation="vertical">

    <include layout="@layout/include_top_bar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="20dp"
        android:paddingTop="8dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvQuizProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/quiz_initial_progress"
                android:textAlignment="center"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="32dp"
                app:cardElevation="12dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_profile_hero"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <TextView
                        android:id="@+id/tvWordLevelLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/english_word_hint"
                        android:textAlignment="center"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvQuestionWord"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/quiz_word_placeholder"
                            android:textAlignment="center"
                            android:textColor="@color/primary"
                            android:textSize="40sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            app:autoSizeMaxTextSize="40sp"
                            app:autoSizeMinTextSize="24sp"
                            app:autoSizeStepGranularity="2sp"
                            app:autoSizeTextType="uniform" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnHint"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="12dp"
                        android:text="@string/hint_action"
                        android:textSize="12sp"
                        app:icon="@drawable/ic_lightbulb"
                        app:iconGravity="start"
                        app:iconPadding="4dp"
                        app:iconSize="18dp"
                        android:visibility="gone" />

                    <ImageView
                        android:id="@+id/ivQuizWordImage"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:layout_marginTop="16dp"
                        android:adjustViewBounds="true"
                        android:background="@drawable/bg_image_preview"
                        android:contentDescription="@string/word_image_content_description"
                        android:scaleType="fitCenter"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvLevelLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/level_default_label"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/lpiWordLevel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            app:indicatorColor="@color/accent"
                            app:trackColor="#E2E8F0"
                            app:trackCornerRadius="4dp"
                            app:trackThickness="8dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvQuizFeedback"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/bg_feedback_neutral"
                        android:minHeight="48dp"
                        android:padding="16dp"
                        android:text="@string/choose_turkish_answer"
                        android:textAlignment="center"
                        android:textColor="@color/text_secondary"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOptionOne"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_quiz_option"
                android:minHeight="64dp"
                android:text="@string/quiz_option_one"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textAllCaps="false"
                app:backgroundTint="@null" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOptionTwo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_quiz_option"
                android:minHeight="64dp"
                android:text="@string/quiz_option_two"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textAllCaps="false"
                app:backgroundTint="@null" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOptionThree"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_quiz_option"
                android:minHeight="64dp"
                android:text="@string/quiz_option_three"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textAllCaps="false"
                app:backgroundTint="@null" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOptionFour"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_quiz_option"
                android:minHeight="64dp"
                android:text="@string/quiz_option_four"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textAllCaps="false"
                app:backgroundTint="@null" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNextQuestion"
                style="@style/AppButtonPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/next_question_action"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFinishQuiz"
                style="@style/AppButtonPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/finish_action"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
