<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:orientation="vertical">

    <include layout="@layout/include_top_bar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="20dp"
        android:paddingTop="8dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvQuizProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/quiz_initial_progress"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="@color/card"
                app:cardCornerRadius="32dp"
                app:cardElevation="10dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_profile_hero"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/english_word_hint"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvQuestionWord"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/quiz_word_placeholder"
                            android:textColor="@color/text_primary"
                            android:textSize="34sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/ivLevelStatus"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginStart="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:padding="4dp"
                            android:src="@drawable/ic_close_red"
                            app:tint="@null" />

                        <ImageView
                            android:id="@+id/ivQuizWordImage"
                            android:layout_width="108dp"
                            android:layout_height="108dp"
                            android:layout_marginStart="16dp"
                            android:adjustViewBounds="true"
                            android:background="@drawable/bg_image_preview"
                            android:contentDescription="@string/word_image_content_description"
                            android:scaleType="centerCrop"
                            android:visibility="gone" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvQuizFeedback"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/bg_feedback_neutral"
                        android:minHeight="44dp"
                        android:padding="14dp"
                        android:text="@string/choose_turkish_answer"
                        android:textColor="@color/text_secondary"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOptionOne"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_quiz_option"
                android:minHeight="56dp"
                android:text="@string/quiz_option_one"
                android:textColor="@color/quiz_option_text" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOptionTwo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_quiz_option"
                android:minHeight="56dp"
                android:text="@string/quiz_option_two"
                android:textColor="@color/quiz_option_text" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOptionThree"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_quiz_option"
                android:minHeight="56dp"
                android:text="@string/quiz_option_three"
                android:textColor="@color/quiz_option_text" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOptionFour"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_quiz_option"
                android:minHeight="56dp"
                android:text="@string/quiz_option_four"
                android:textColor="@color/quiz_option_text" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNextQuestion"
                style="@style/AppButtonPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/next_question_action"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFinishQuiz"
                style="@style/AppButtonPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/finish_action"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
