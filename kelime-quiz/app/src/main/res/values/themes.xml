<resources>
    <style name="Theme.KelimeQuiz" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryContainer">@color/purple_700</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSurface">@color/surface_soft</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/surface</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:fontFamily">sans</item>
    </style>

    <style name="AppButtonPrimary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/teal_200</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:textColor">@color/text_dark</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">52dp</item>
    </style>

    <style name="AppButtonSecondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">18dp</item>
        <item name="strokeColor">@color/purple_500</item>
        <item name="android:textColor">@color/text_dark</item>
        <item name="android:minHeight">52dp</item>
    </style>

    <style name="AppButtonGhost" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/teal_200</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AppInput" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/card</item>
        <item name="boxCornerRadiusTopStart">18dp</item>
        <item name="boxCornerRadiusTopEnd">18dp</item>
        <item name="boxCornerRadiusBottomStart">18dp</item>
        <item name="boxCornerRadiusBottomEnd">18dp</item>
        <item name="hintTextColor">@color/text_dark_secondary</item>
        <item name="android:textColorHint">@color/text_dark_secondary</item>
    </style>
</resources>
